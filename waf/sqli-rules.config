# ModSecurity SQL Injection Rules

# Rule 1000: SQL keywords
SecRule ARGS "@rx (?:union|select|insert|update|delete|drop)" \
  "id:1000,phase:2,deny,status:403,msg:'SQL keyword detected'"

# Rule 1001: SQL comments
SecRule ARGS "@rx (--|#|/\*|\*/)" \
  "id:1001,phase:2,deny,status:403,msg:'SQL comment detected'"

# Rule 1002: OR conditions
SecRule ARGS "@rx ' OR '.*'=" \
  "id:1002,phase:2,deny,status:403,msg:'SQL OR condition detected'"

# Rule 1003: SLEEP function
SecRule ARGS "@rx SLEEP\s*\(" \
  "id:1003,phase:2,deny,status:403,msg:'Time-based SQLi detected'"

# Rule 1004: UNION SELECT
SecRule ARGS "@rx UNION\s+SELECT" \
  "id:1004,phase:2,deny,status:403,msg:'UNION-based SQLi detected'"

# Rule 1005: AND/OR boolean
SecRule ARGS "@rx '\s*(AND|OR)\s+1\s*=" \
  "id:1005,phase:2,deny,status:403,msg:'Boolean-based SQLi detected'"

# Rule 2000: Block POST method
SecRule REQUEST_METHOD "@rx POST" \
  "id:2000,phase:1,deny,status:405,msg:'POST method not allowed'"
